{
  "devDependencies": {
    "@types/google-apps-script": "^2.0.8",
    "typescript": "^5.9.3",
    "@google/clasp": "^2.4.2"
  },
  "scripts": {
    "build": "tsc && copy appsscript.json dist\\ && copy src\\*.html dist\\",
    "push": "npm run build && clasp push",
    "pull": "clasp pull",
    "build:webhook": "tsc --project webhook/tsconfig.json && copy webhook\\appsscript.json webhook\\dist\\",
    "push:webhook": "npm run build:webhook && clasp push --project webhook",
    "pull:webhook": "clasp pull --project webhook"
  }
}
